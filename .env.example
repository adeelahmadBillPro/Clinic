# Copy this file to .env and fill in values.

# ─── Database ───────────────────────────────────────────────────────────
# URL-encode any special characters in the password (e.g. `@` -> `%40`).
DATABASE_URL="postgresql://postgres:password@localhost:5432/clinicos_db?schema=public"

# ─── NextAuth (v5) ──────────────────────────────────────────────────────
# v5 reads AUTH_SECRET; NEXTAUTH_SECRET is kept for backwards compat.
# Generate with `openssl rand -base64 32`.
AUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""
AUTH_TRUST_HOST="true"

# ─── Stripe ─────────────────────────────────────────────────────────────
# STRIPE_WEBHOOK_SECRET is REQUIRED for /api/webhooks/stripe to accept
# events — the route hard-fails on missing secret or invalid signature.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# ─── Twilio ─────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"
TWILIO_SMS_FROM=""

# ─── Resend (email) ─────────────────────────────────────────────────────
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@clinicos.app"

# ─── Cloudinary (image uploads) ─────────────────────────────────────────
# Used by /api/upload/avatar for user and doctor avatars. Uploads are
# rejected with 501 if these are unset.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
