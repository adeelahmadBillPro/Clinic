// ClinicOS - Full Prisma Schema
// Multi-tenant SaaS clinic management system
// Isolation: row-level (every tenant model has clinicId + index)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── PUBLIC SCHEMA ─────────────────────────────────────────

// Email is globally unique — one person, one account, one clinic. The
// login flow resolves by email alone, which would need a clinic selector
// to support multi-clinic staff. Keep simple for now; flag for review if
// we ever need a receptionist to serve two clinics from one email.
model User {
  id                   String    @id @default(cuid())
  name                 String
  email                String    @unique
  phone                String?
  password             String
  role                 Role
  clinicId             String?
  photoUrl             String?
  isActive             Boolean   @default(true)
  // Email verification — null until the user clicks the link in the
  // signup email. `auth.ts` rejects logins when this is null.
  emailVerifiedAt      DateTime?
  emailVerifyTokenHash String?
  // Set when the user checks the terms & privacy box at signup (P4-51).
  acceptedTermsAt      DateTime?
  lastLoginAt          DateTime?
  failedLoginAttempts  Int       @default(0)
  lockedUntil          DateTime?
  resetOtpHash         String?
  resetOtpExpiresAt    DateTime?
  createdAt            DateTime  @default(now())

  @@index([clinicId])
}

model Clinic {
  id               String    @id @default(cuid())
  name             String
  slug             String    @unique
  phone            String?
  address          String?
  logoUrl          String?
  ownerId          String
  planId           String
  trialEndsAt      DateTime?
  subscriptionId   String?
  stripeCustomerId String?
  isActive         Boolean   @default(true)
  settings         Json      @default("{}")
  createdAt        DateTime  @default(now())

  // Reverse relations — Prisma needs these declared to generate the FK
  // constraints on the child side. `onDelete: Cascade` lives on the child;
  // here we just expose the collections.
  patients         Patient[]
  doctors          Doctor[]
  tokens           Token[]
  appointments     Appointment[]
  consultations    Consultation[]
  vitals           VitalSigns[]
  prescriptions    Prescription[]
  medicines        Medicine[]
  pharmacyOrders   PharmacyOrder[]
  suppliers        Supplier[]
  purchaseOrders   PurchaseOrder[]
  stockMovements   StockMovement[]
  beds             Bed[]
  admissions       IpdAdmission[]
  nursingNotes     NursingNote[]
  labOrders        LabOrder[]
  bills            Bill[]
  cashShifts       CashShift[]
  auditLogs        AuditLog[]
  notifications    Notification[]
  reviews          Review[]
  upgradeRequests  UpgradeRequest[]
  subscriptions    Subscription[]
  counters         Counter[]
  rxTemplates      PrescriptionTemplate[]
}

model Plan {
  id                   String   @id @default(cuid())
  name                 String   @unique
  monthlyPrice         Decimal
  yearlyPrice          Decimal?
  oneTimePrice         Decimal?
  maxDoctors           Int
  maxPatients          Int
  features             Json
  stripePriceIdMonthly String?
  stripePriceIdYearly  String?
  isActive             Boolean  @default(true)
}

model Subscription {
  id                   String    @id @default(cuid())
  clinicId             String    @unique
  stripeSubscriptionId String?
  planId               String
  status               String
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)
  createdAt            DateTime  @default(now())

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)
}

model UpgradeRequest {
  id              String    @id @default(cuid())
  clinicId        String
  submittedBy     String
  submitterName   String
  submitterEmail  String
  planName        String
  cycle           String
  method          String
  referenceNumber String
  amountPaid      Decimal
  notes           String?
  status          String    @default("PENDING") // PENDING | APPROVED | REJECTED
  reviewedBy      String?
  reviewerName    String?
  reviewedAt      DateTime?
  reviewNotes     String?
  createdAt       DateTime  @default(now())

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([clinicId])
}

// ─── TENANT MODELS (row-level isolation via clinicId) ──────

model Patient {
  id                String    @id @default(cuid())
  clinicId          String
  mrn               String
  name              String
  phone             String
  dob               DateTime?
  gender            String
  address           String?
  bloodGroup        String?
  allergies         String[]
  chronicConditions String[]
  emergencyContact  String?
  emergencyPhone    String?
  // Honour "STOP" replies and clinic-flagged opt-outs. Every callsite of
  // sendWhatsApp for patient messages must check this first.
  optOutWhatsApp    Boolean   @default(false)
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([clinicId, mrn])
  @@index([clinicId])
  @@index([clinicId, phone])
  @@index([clinicId, name])
}

model Review {
  id             String   @id @default(cuid())
  clinicId       String
  doctorId       String
  appointmentId  String?
  patientId      String?
  reviewerName   String
  reviewerPhone  String?
  rating         Int
  comment        String?
  // Reviews enter a moderation queue by default — an admin must publish.
  // Previously published by default, which made review abuse trivial.
  isPublished    Boolean  @default(false)
  createdAt      DateTime @default(now())

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId, doctorId])
  @@index([clinicId, createdAt])
}

model Doctor {
  id              String   @id @default(cuid())
  clinicId        String
  userId          String   @unique
  specialization  String
  qualification   String
  roomNumber      String?
  consultationFee Decimal
  isAvailable     Boolean  @default(true)
  status          String   @default("AVAILABLE")
  schedule        Json
  revenueSharePct Decimal  @default(0)
  photoUrl        String?
  experienceYears Int      @default(0)
  about           String?
  languages       String[] @default([])
  gender          String?
  whatsappNumber  String?

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId])
}

model Token {
  id             String      @id @default(cuid())
  clinicId       String
  tokenNumber    Int
  displayToken   String
  patientId      String
  doctorId       String
  type           VisitType
  chiefComplaint String?
  status         TokenStatus
  issuedBy       String
  issuedAt       DateTime    @default(now())
  expiresAt      DateTime
  calledAt       DateTime?
  startedAt      DateTime?
  completedAt    DateTime?
  cancelReason   String?

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId, status])
  @@index([clinicId, doctorId, issuedAt])
}

model Appointment {
  id              String     @id @default(cuid())
  clinicId        String
  patientId       String?
  patientName     String
  patientPhone    String
  doctorId        String
  appointmentDate DateTime
  timeSlot        String
  type            String
  status          ApptStatus
  tokenId         String?
  notes           String?
  bookedVia       String     @default("RECEPTION")
  createdAt       DateTime   @default(now())

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId, appointmentDate])
  @@index([clinicId, doctorId, appointmentDate])
}

model Consultation {
  id             String    @id @default(cuid())
  clinicId       String
  tokenId        String
  patientId      String
  doctorId       String
  chiefComplaint String
  subjective     String?
  objective      String?
  assessment     String?
  plan           String?
  diagnosisCodes Json?
  referredTo     String?
  followUpDate   DateTime?
  followUpNotes  String?
  createdAt      DateTime  @default(now())

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId, patientId])
  @@index([clinicId, doctorId])
}

model VitalSigns {
  id             String   @id @default(cuid())
  clinicId       String
  patientId      String
  consultationId String?
  recordedBy     String
  bp             String?
  pulse          Int?
  temperature    Decimal?
  weight         Decimal?
  height         Decimal?
  spO2           Int?
  bloodSugar     Decimal?
  bmi            Decimal?
  recordedAt     DateTime @default(now())

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId, patientId])
}

model Prescription {
  id             String             @id @default(cuid())
  clinicId       String
  consultationId String
  patientId      String
  doctorId       String
  medicines      Json
  notes          String?
  status         PrescriptionStatus
  sentAt         DateTime?
  createdAt      DateTime           @default(now())

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId, status])
  @@index([clinicId, patientId])
}

model Medicine {
  id            String    @id @default(cuid())
  clinicId      String
  name          String
  genericName   String?
  category      String
  unit          String
  stockQty      Decimal   @default(0)
  minStockLevel Decimal   @default(10)
  purchasePrice Decimal
  salePrice     Decimal
  batchNumber   String?
  expiryDate    DateTime?
  supplierId    String?
  location      String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId, name])
  @@index([clinicId, isActive])
}

model PharmacyOrder {
  id             String      @id @default(cuid())
  clinicId       String
  orderNumber    String
  prescriptionId String?
  patientId      String
  items          Json
  totalAmount    Decimal
  paidAmount     Decimal     @default(0)
  status         OrderStatus
  dispensedBy    String?
  notes          String?
  createdAt      DateTime    @default(now())

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([clinicId, orderNumber])
  @@index([clinicId, status])
}

model Supplier {
  id        String   @id @default(cuid())
  clinicId  String
  name      String
  contact   String?
  phone     String?
  email     String?
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId])
}

model PurchaseOrder {
  id            String    @id @default(cuid())
  clinicId      String
  poNumber      String
  supplierId    String
  items         Json
  totalAmount   Decimal
  status        POStatus
  orderedAt     DateTime?
  receivedAt    DateTime?
  invoiceNumber String?
  notes         String?
  createdBy     String
  createdAt     DateTime  @default(now())

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([clinicId, poNumber])
  @@index([clinicId, status])
}

model StockMovement {
  id         String   @id @default(cuid())
  clinicId   String
  medicineId String
  type       String
  qty        Decimal
  reason     String?
  reference  String?
  doneBy     String
  createdAt  DateTime @default(now())

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId, medicineId])
}

model Bed {
  id               String  @id @default(cuid())
  clinicId         String
  bedNumber        String
  wardName         String
  bedType          String
  dailyRate        Decimal
  isOccupied       Boolean @default(false)
  isActive         Boolean @default(true)
  currentPatientId String?

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([clinicId, bedNumber])
  @@index([clinicId, isOccupied])
}

model IpdAdmission {
  id                 String          @id @default(cuid())
  clinicId           String
  admissionNumber    String
  patientId          String
  bedId              String
  doctorId           String
  admissionDate      DateTime        @default(now())
  admissionNotes     String?
  admissionDiagnosis String?
  dischargeDate      DateTime?
  dischargeDiagnosis String?
  dischargeNotes     String?
  status             AdmissionStatus
  totalCharges       Decimal         @default(0)

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([clinicId, admissionNumber])
  @@index([clinicId, status])
}

model NursingNote {
  id           String   @id @default(cuid())
  clinicId     String
  admissionId  String
  patientId    String
  nurseId      String
  shift        String
  vitals       Json?
  medications  Json?
  observations String?
  createdAt    DateTime @default(now())

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId, admissionId])
}

model LabOrder {
  id                String    @id @default(cuid())
  clinicId          String
  orderNumber       String
  patientId         String
  doctorId          String
  consultationId    String?
  admissionId       String?
  tests             Json
  totalAmount       Decimal
  status            LabStatus
  results           Json?
  reportUrl         String?
  processedBy       String?
  sampleCollectedAt DateTime?
  completedAt       DateTime?
  createdAt         DateTime  @default(now())

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([clinicId, orderNumber])
  @@index([clinicId, status])
}

model Bill {
  id             String     @id @default(cuid())
  clinicId       String
  billNumber     String
  patientId      String
  // Attributing bills to doctors by matching bill-item description against
  // the doctor's specialization produced wrong splits when two doctors
  // shared a specialization. Store the doctorId explicitly when the bill
  // is generated so stats can filter by it.
  doctorId       String?
  billType       BillType
  admissionId    String?
  items          Json
  subtotal       Decimal
  discount       Decimal    @default(0)
  discountReason String?
  totalAmount    Decimal
  paidAmount     Decimal    @default(0)
  balance        Decimal
  paymentMethod  String?
  insuranceInfo  Json?
  status         BillStatus
  collectedBy    String
  notes          String?
  createdAt      DateTime   @default(now())

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([clinicId, billNumber])
  @@index([clinicId, status])
  @@index([clinicId, createdAt])
  @@index([clinicId, doctorId])
}

model CashShift {
  id             String    @id @default(cuid())
  clinicId       String
  userId         String
  shiftDate      DateTime
  shiftType      String
  openingBalance Decimal   @default(0)
  totalCollected Decimal
  declaredCash   Decimal
  difference     Decimal
  status         String
  notes          String?
  approvedBy     String?
  submittedAt    DateTime?
  createdAt      DateTime  @default(now())

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  // One shift row per (user, day, shift type) — prevents double-open and
  // double-submit when a user refreshes the end-of-shift form.
  @@unique([clinicId, userId, shiftDate, shiftType])
  @@index([clinicId, shiftDate])
  @@index([clinicId, userId])
}

model AuditLog {
  id         String   @id @default(cuid())
  clinicId   String
  userId     String
  userName   String
  action     String
  entityType String
  entityId   String?
  details    Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId, createdAt])
  @@index([clinicId, userId])
  @@index([clinicId, action])
}

model Notification {
  id        String    @id @default(cuid())
  clinicId  String
  userId    String?
  patientId String?
  type      String
  channel   String
  message   String
  status    String
  sentAt    DateTime?
  createdAt DateTime  @default(now())

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId, status])
  @@index([clinicId, userId])
}

// Per-doctor prescription templates. Previously stored in localStorage,
// which meant templates vanished when the doctor moved between devices
// (or between dev/prod). One row per (clinic, user, name).
model PrescriptionTemplate {
  id        String   @id @default(cuid())
  clinicId  String
  userId    String
  name      String
  items     Json
  createdAt DateTime @default(now())

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([clinicId, userId, name])
  @@index([clinicId, userId])
}

// Per-(clinic, kind, year) atomic sequence counter. The prior pattern of
// "findFirst desc + parse digits + +1" raced under concurrent writes and
// could produce duplicate bill / PO / lab / admission numbers.
// `src/lib/counter.ts` upserts then increments in a single statement.
model Counter {
  id        String   @id @default(cuid())
  clinicId  String
  kind      String
  year      Int
  value     Int      @default(0)
  updatedAt DateTime @updatedAt

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([clinicId, kind, year])
  @@index([clinicId])
}

// ─── ENUMS ──────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  OWNER
  ADMIN
  DOCTOR
  RECEPTIONIST
  NURSE
  PHARMACIST
  LAB_TECH
}

enum VisitType {
  OPD
  IPD
  EMERGENCY
}

enum TokenStatus {
  WAITING
  CALLED
  IN_PROGRESS
  COMPLETED
  EXPIRED
  CANCELLED
}

enum ApptStatus {
  SCHEDULED
  CONFIRMED
  CHECKED_IN
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum PrescriptionStatus {
  PENDING
  SENT_TO_PHARMACY
  DISPENSED
  PARTIAL
  CANCELLED
}

enum OrderStatus {
  PENDING
  DISPENSED
  PARTIAL
  CANCELLED
}

enum POStatus {
  DRAFT
  ORDERED
  RECEIVED
  CANCELLED
}

enum LabStatus {
  ORDERED
  SAMPLE_COLLECTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum AdmissionStatus {
  ADMITTED
  DISCHARGED
}

enum BillType {
  OPD
  PHARMACY
  IPD
  LAB
}

enum BillStatus {
  PENDING
  PAID
  PARTIAL
  CANCELLED
  REFUNDED
}
